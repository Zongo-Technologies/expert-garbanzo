{
  "name": "worker-que",
  "version": "1.1.1",
  "description": "A TypeScript job queue library for PostgreSQL with real-time web dashboard, SSL support, and cross-language compatibility",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dashboard": {
      "require": "./dist/dashboard/index.js",
      "import": "./dist/dashboard/index.js",
      "types": "./dist/dashboard/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "migrations/",
    "README.md",
    "LICENSE",
    "DASHBOARD.md",
    "SSL.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "test": "jest --testTimeout=5000",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "jest --detectOpenHandles --testTimeout=5000",
    "test:docker": "npm run docker:up && npm run test && npm run docker:down",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run lint && npm run build",
    "clean": "rm -rf dist",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f postgres",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "docker:reset": "npm run docker:clean && npm run docker:up"
  },
  "keywords": [
    "job-queue",
    "worker-queue",
    "postgresql",
    "postgres",
    "typescript",
    "background-jobs",
    "job-processing",
    "task-queue",
    "async-jobs",
    "que",
    "worker",
    "dashboard",
    "queue-monitoring",
    "express",
    "ssl",
    "tls",
    "advisory-locks"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.2",
    "@types/pg": "^8.10.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "dotenv": "^17.2.1",
    "eslint": "^8.57.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "dependencies": {
    "pg": "^8.11.3",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "express-session": "^1.17.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "express-session": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zongo-Technologies/expert-garbanzo.git"
  },
  "bugs": {
    "url": "https://github.com/Zongo-Technologies/expert-garbanzo/issues"
  },
  "homepage": "https://github.com/Zongo-Technologies/expert-garbanzo#readme"
}
